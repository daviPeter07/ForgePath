Output docs/demo.gif

Set FontSize 18
Set FontFamily "JetBrainsMono Nerd Font"
Set Width 1200
Set Height 600
Set Padding 40
Set Theme "Catppuccin Macchiato"
Set WindowBar Colorful
Set WindowBarSize 40

# Start forgepath
Type "fg"
Enter
Sleep 1s

# Navigate and search
Type "forg"
Sleep 1s
Type "e"
Sleep 1s
Enter
Sleep 1.5s

# Open Docker menu
Type "d"
Sleep 1.5s

# Select Postgres option
Down
Down
Down
Sleep 1s
Enter

# Show success message
Sleep 2s
